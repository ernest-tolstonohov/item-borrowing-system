<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="app.AddItemController" stylesheets="@styles.css">

    <top>
        <VBox>
            <HBox style="-fx-background-color: #2d3748; -fx-padding: 20;" alignment="CENTER_LEFT"
                spacing="20">
                <Label text="📚 Library of Stuff"
                    style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="usernameLabel" style="-fx-text-fill: #a0aec0; -fx-font-size: 14px;" />
                <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: #e53e3e; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 8 16 8 16; -fx-background-radius: 6; -fx-cursor: hand;" />
            </HBox>

            <HBox
                style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 2 0;">
                <Button text="🔍 Browse Items" onAction="#showBrowse" styleClass="nav-button" />
                <Button text="📦 My Items" onAction="#showMyItems" styleClass="nav-button" />
                <Button text="🎒 My Borrowed" onAction="#showBorrowed" styleClass="nav-button" />
                <Button text="➕ Add Item" onAction="#showAddItem"
                    styleClass="nav-button,nav-button-active" />
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f7fafc;">
            <VBox alignment="TOP_CENTER" style="-fx-padding: 30;">

                <VBox maxWidth="800" spacing="0"
                    style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 4, 0, 0, 4);">

                    <!-- Header -->
                    <VBox spacing="10"
                        style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-padding: 30;">
                        <Label text="Add New Item"
                            style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" />
                        <Label text="Fill in the details to add a new item to your collection"
                            style="-fx-text-fill: white; -fx-font-size: 14px;" />
                    </VBox>

                    <!-- Form -->
                    <VBox spacing="20" style="-fx-padding: 30;">

                        <!-- Item Name -->
                        <VBox spacing="8">
                            <Label text="Item Name *"
                                style="-fx-font-size: 14px; -fx-font-weight: 500; -fx-text-fill: #4a5568;" />
                            <TextField fx:id="nameField" promptText="e.g., Hammer, Pot, Shovel"
                                style="-fx-font-size: 14px; -fx-padding: 12 15 12 15; -fx-border-color: #e2e8f0; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8;" />
                        </VBox>

                        <!-- Category -->
                        <VBox spacing="8">
                            <Label text="Category *"
                                style="-fx-font-size: 14px; -fx-font-weight: 500; -fx-text-fill: #4a5568;" />
                            <ComboBox fx:id="categoryCombo" promptText="Select a category"
                                maxWidth="Infinity"
                                style="-fx-font-size: 14px; -fx-padding: 8 12 8 12;" />
                        </VBox>

                        <!-- Condition -->
                        <VBox spacing="8">
                            <Label text="Condition *"
                                style="-fx-font-size: 14px; -fx-font-weight: 500; -fx-text-fill: #4a5568;" />
                            <ComboBox fx:id="conditionCombo" promptText="Select condition"
                                maxWidth="Infinity"
                                style="-fx-font-size: 14px; -fx-padding: 8 12 8 12;" />
                        </VBox>

                        <!-- Special Property -->
                        <VBox fx:id="specialPropertyBox" spacing="8" managed="false" visible="false">
                            <Label fx:id="specialPropertyLabel" text="Special Property *"
                                style="-fx-font-size: 14px; -fx-font-weight: 500; -fx-text-fill: #4a5568;" />
                            <TextField fx:id="specialPropertyField" promptText=""
                                style="-fx-font-size: 14px; -fx-padding: 12 15 12 15; -fx-border-color: #e2e8f0; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8;" />
                            <Label fx:id="specialPropertyHint"
                                style="-fx-text-fill: #718096; -fx-font-size: 12px;" wrapText="true" />
                        </VBox>

                        <!-- Info message -->
                        <HBox spacing="10"
                            style="-fx-background-color: #bee3f8; -fx-padding: 15 20 15 20; -fx-background-radius: 8; -fx-border-color: #3182ce; -fx-border-width: 0 0 0 4;">
                            <Label
                                text="The special property field changes based on the category you select"
                                style="-fx-text-fill: #2c5282; -fx-font-size: 13px;" wrapText="true"
                                HBox.hgrow="ALWAYS" />
                        </HBox>

                        <!-- Error label -->
                        <Label fx:id="errorLabel"
                            style="-fx-text-fill: #e53e3e; -fx-font-size: 13px;" wrapText="true" />

                        <!-- Buttons -->
                        <HBox spacing="10">
                            <Button text="Add Item" onAction="#handleAddItem"
                                style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 600; -fx-padding: 12 24 12 24; -fx-background-radius: 8; -fx-cursor: hand;" />
                            <Button text="Cancel" onAction="#showBrowse"
                                style="-fx-background-color: #e2e8f0; -fx-text-fill: #4a5568; -fx-font-size: 14px; -fx-padding: 12 24 12 24; -fx-background-radius: 8; -fx-cursor: hand;" />
                        </HBox>

                    </VBox>

                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>