<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="app.BorrowedController" stylesheets="@styles.css">

    <top>
        <VBox>
            <HBox style="-fx-background-color: #2d3748; -fx-padding: 20;" alignment="CENTER_LEFT"
                spacing="20">
                <Label text="📚 Library of Stuff"
                    style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="usernameLabel" style="-fx-text-fill: #a0aec0; -fx-font-size: 14px;" />
                <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: #e53e3e; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 8 16 8 16; -fx-background-radius: 6; -fx-cursor: hand;" />
            </HBox>

            <HBox
                style="-fx-background-color: #f7fafc; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 2 0;">
                <Button text="🔍 Browse Items" onAction="#showBrowse" styleClass="nav-button" />
                <Button text="📦 My Items" onAction="#showMyItems" styleClass="nav-button" />
                <Button text="🎒 My Borrowed" onAction="#showBorrowed"
                    styleClass="nav-button,nav-button-active" />
                <Button text="➕ Add Item" onAction="#showAddItem" styleClass="nav-button" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="0" style="-fx-padding: 30; -fx-background-color: #f7fafc;">

            <VBox spacing="15"
                style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 4, 0, 0, 4);">

                <HBox alignment="CENTER_LEFT" spacing="15"
                    style="-fx-padding: 20; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 2 0;">
                    <Label fx:id="titleLabel" text="Items I'm Borrowing (0)"
                        style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" />
                    <Region HBox.hgrow="ALWAYS" />
                </HBox>

                <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn text="ID" prefWidth="60">
                            <cellValueFactory>
                                <PropertyValueFactory property="id" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Name" prefWidth="150">
                            <cellValueFactory>
                                <PropertyValueFactory property="name" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Category" prefWidth="120">
                            <cellValueFactory>
                                <PropertyValueFactory property="category" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Owner" prefWidth="120">
                            <cellValueFactory>
                                <PropertyValueFactory property="ownerName" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Actions" prefWidth="150" />
                    </columns>
                </TableView>

            </VBox>

        </VBox>
    </center>

</BorderPane>